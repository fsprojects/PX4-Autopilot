{
  "description": "Test cases for PX4 atmosphere library correspondence validation",
  "source": "src/lib/atmosphere/atmosphere.{h,cpp}",
  "lean_model": "formal-verification/lean/FVSquad/Atmosphere.lean",
  "density_cases": [
    {"pressure_pa": 101325.0, "temperature_celsius": 15.0,  "note": "ISA sea-level standard"},
    {"pressure_pa": 101325.0, "temperature_celsius":  0.0,  "note": "0 celsius SL"},
    {"pressure_pa": 101325.0, "temperature_celsius": 30.0,  "note": "hot day"},
    {"pressure_pa":  89875.0, "temperature_celsius":  8.5,  "note": "~1000 m ISA"},
    {"pressure_pa":  54048.0, "temperature_celsius": -17.5, "note": "~5000 m ISA"},
    {"pressure_pa":  22632.0, "temperature_celsius": -56.5, "note": "~11000 m ISA (tropopause)"},
    {"pressure_pa": 120000.0, "temperature_celsius": 40.0,  "note": "extreme hot/high-pressure"},
    {"pressure_pa":  10000.0, "temperature_celsius": -60.0, "note": "stratosphere approx"},
    {"pressure_pa":    500.0, "temperature_celsius": -20.0, "note": "low pressure, cold"},
