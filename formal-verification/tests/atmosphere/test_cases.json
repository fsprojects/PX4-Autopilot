    {"altitude_m":  8000.0, "note": "8 km"},
    {"altitude_m": 10000.0, "note": "10 km"},
    {"altitude_m": 11000.0, "note": "tropopause (11 km)"},
    {"altitude_m":  -420.0, "note": "Dead Sea (negative altitude)"},
    {"altitude_m": 15000.0, "note": "stratosphere extrapolation (outside ISA validity)"},
    {"altitude_m":   500.0, "note": "500 m"}
  ]
}
